export DEB_BUILD_MAINT_OPTIONS = hardening=+all
include /usr/share/dpkg/architecture.mk

%:
	dh $@ --buildsystem=cmake+ninja

# qmllintgate pins the Nix toolchain. schemesmodeltest's XDG fixture cannot
# hide the application's deliberate /usr/share BreezeLight fallback, which
# exists on neon. The final gate runs both; the package build runs the other 92.
override_dh_auto_test:
	cd obj-$(DEB_HOST_GNU_TYPE) && \
		LC_ALL=C.UTF-8 ctest --output-on-failure \
			--exclude-regex '^(qmllintgate|schemesmodeltest)$$'
